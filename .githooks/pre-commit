#!/usr/bin/env bash
#
# Pre-commit security hook. Runs two best-effort scanners on staged content;
# each is skipped (with a notice) when its tool is not installed.
#
#   gitleaks -- secret detection by pattern over ALL staged files (any type:
#               .py, .env, .yaml, .json...). Catches API keys, tokens, private
#               keys, and high-entropy strings that bandit's name-based checks
#               miss.
#
#   bandit   -- static analysis of staged Python source. Blocks on:
#                 * hardcoded passwords / secrets  (B105, B106, B107)
#                 * any medium+ severity AND medium+ confidence issue
#                   (SQL injection B608, shell injection, unsafe
#                   deserialization) -- the bug classes that matter for a
#                   public, SQL-backed web service.
#
# Escape hatches:
#   * gitleaks: add an inline  gitleaks:allow  comment on an audited line,
#     or register the finding in a .gitleaksignore file
#   * bandit:   annotate an audited false positive with a trailing  # nosec
#   * either:   bypass the whole hook with  git commit --no-verify
#
set -uo pipefail

status=0

# ---------------------------------------------------------------------------
# gitleaks: secret scan over staged content.
# ---------------------------------------------------------------------------
if command -v gitleaks >/dev/null 2>&1; then
    # The staged-scan subcommand was renamed from `protect` to `git` in
    # gitleaks 8.18; prefer the newer form and fall back for older binaries.
    if gitleaks git --help >/dev/null 2>&1; then
        gitleaks_cmd=(gitleaks git --staged)
    else
        gitleaks_cmd=(gitleaks protect --staged)
    fi
    if ! "${gitleaks_cmd[@]}" --no-banner --redact --verbose; then
        echo >&2
        echo "pre-commit: gitleaks found a possible secret (see above)." >&2
        status=1
    fi
else
    echo "pre-commit: gitleaks not installed; skipping secret scan." >&2
    echo "            install from https://github.com/gitleaks/gitleaks/releases" >&2
fi

# ---------------------------------------------------------------------------
# bandit: static analysis of staged Python source.
# ---------------------------------------------------------------------------
if command -v bandit >/dev/null 2>&1; then
    # Staged Python files (Added/Copied/Modified; skip deletions), excluding
    # non-source / generated trees and test fixtures (which may carry
    # intentional fake credentials).
    mapfile -t files < <(git diff --cached --name-only --diff-filter=ACM -z \
        | tr '\0' '\n' \
        | grep -E '\.py$' \
        | grep -Ev '^(tests|build|notebooks|trash|data|geo_search\.egg-info)/' || true)

    # Keep only paths still present in the working tree.
    present=()
    for f in "${files[@]:-}"; do
        [ -n "$f" ] && [ -f "$f" ] && present+=("$f")
    done

    if [ "${#present[@]}" -gt 0 ]; then
        # Pass 1: hardcoded passwords / secrets (LOW severity, but in scope).
        if ! bandit -q -t B105,B106,B107 "${present[@]}"; then
            echo >&2
            echo "pre-commit: bandit found a possible hardcoded secret (see above)." >&2
            status=1
        fi
        # Pass 2: medium+ severity AND medium+ confidence findings.
        if ! bandit -q -ll -ii "${present[@]}"; then
            echo >&2
            echo "pre-commit: bandit found a medium+ severity security issue (see above)." >&2
            status=1
        fi
    fi
else
    echo "pre-commit: bandit not installed; skipping Python security scan." >&2
    echo "            install it with  pip install -e \".[dev]\"" >&2
fi

if [ "$status" -ne 0 ]; then
    echo >&2
    echo "Commit aborted by the security hook. Fix the issue, annotate an audited" >&2
    echo "false positive (gitleaks:allow / # nosec), or bypass with --no-verify." >&2
fi

exit "$status"
